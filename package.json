{
  "name": "reclip-downloader",
  "private": true,
  "version": "0.1.0",
  "packageManager": "npm@10",
  "engines": {
    "node": "24.x",
    "npm": "10.x"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev -w @reclip/api\" \"npm run dev -w @reclip/worker\" \"npm run dev -w @reclip/web\"",
    "build": "npm run build -ws --if-present",
    "test": "vitest run"
  },
  "devDependencies": {
    "concurrently": "^9.0.1",
    "typescript": "^5.6.2",
    "vitest": "^2.1.1"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "lucide-react": "^1.14.0",
    "next": "^16.2.6",
    "react": "^18.3.1",
    "tailwindcss": "^4.3.0"
  }
}
